<?xml version="1.0" encoding="utf-8"?>
<!-- activity_catalog.xml
     Tela Principal — Catálogo de Produtos — RF01.
     Exibe categorias (vestidos, blusas, calças, saias, conjuntos)
     e filtros por categoria, tamanho e cor. -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- AppBar com barra de busca e ícone do carrinho -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_primary"
        app:elevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/catalog_greeting"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/playfair_display"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btnCart"/>

            <!-- Ícone do Carrinho com badge -->
            <FrameLayout
                android:id="@+id/btnCart"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageButton
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_cart"
                    android:contentDescription="@string/cart"/>

                <com.google.android.material.badge.BadgeDrawable
                    android:id="@+id/cartBadge"/>
            </FrameLayout>

            <!-- Barra de Busca -->
            <com.google.android.material.search.SearchBar
                android:id="@+id/searchBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="@string/search_hint"
                app:strokeColor="@color/stroke_light"
                app:strokeWidth="1dp"
                android:layout_marginTop="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvGreeting"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Chips de Filtro: Categoria -->
        <HorizontalScrollView
            android:id="@+id/scrollCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="false">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_all"
                    app:chipBackgroundColor="@color/chip_selected_bg"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDresses"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cat_vestidos"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBlouses"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cat_blusas"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPants"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cat_calcas"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSkirts"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cat_saias"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSets"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cat_conjuntos"/>

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- Linha de Filtros adicionais: Tamanho e Cor -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilterSize"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/filter_size"
                android:textSize="12sp"
                app:strokeColor="@color/accent_pink"
                app:cornerRadius="18dp"
                android:drawableEnd="@drawable/ic_arrow_down"
                android:paddingStart="12dp"
                android:paddingEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilterColor"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/filter_color"
                android:textSize="12sp"
                app:strokeColor="@color/accent_pink"
                app:cornerRadius="18dp"
                android:drawableEnd="@drawable/ic_arrow_down"
                android:paddingStart="12dp"
                android:paddingEnd="8dp"
                android:layout_marginStart="8dp"/>

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

            <TextView
                android:id="@+id/tvResultCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/result_count_placeholder"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Grid de Produtos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProducts"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"/>

    <!-- FAB do Carrinho (atalho) -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabCart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/fab_cart"
        android:textColor="@color/white"
        app:backgroundTint="@color/accent_pink"
        app:icon="@drawable/ic_cart"
        app:iconTint="@color/white"
        android:layout_margin="16dp"
        app:layout_anchor="@id/rvProducts"
        app:layout_anchorGravity="bottom|end"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>